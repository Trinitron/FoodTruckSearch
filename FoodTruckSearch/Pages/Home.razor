@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Food Trucks Map</PageTitle>

<h1>Nearby Food Trucks</h1>

<div class="row g-2 mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label">Latitude</label>
        <input type="number" class="form-control" step="0.0001" @bind="searchLat" />
    </div>
    <div class="col-auto">
        <label class="form-label">Longitude</label>
        <input type="number" class="form-control" step="0.0001" @bind="searchLng" />
    </div>
    <div class="col-auto">
        <label class="form-label">Results</label>
        <input type="number" class="form-control" style="width:80px" min="1" max="100" @bind="resultCount" />
    </div>
    <div class="col-auto">
        <label class="form-label">Preferred food</label>
        <input type="text" class="form-control" placeholder="e.g. tacos" @bind="foodFilter" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" @onclick="Search">Search</button>
    </div>
    <div class="col-auto">
        <button class="btn btn-secondary" @onclick="UseMyLocation">Use my location</button>
    </div>
</div>

<span class="text-muted small">@status</span>

<div id="map" style="height:600px; width:100%; margin-top:1rem;"></div>

@code {
    private double searchLat = 37.7749;
    private double searchLng = -122.4194;
    private int resultCount = 10;
    private string foodFilter = "";
    private string status = "";
    private List<Truck> allTrucks = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadCsvAsync();
            await Search();
            //await UseMyLocation();
        }
    }

    private async Task UseMyLocation()
    {
        try
        {
            status = "Detecting location...";
            StateHasChanged();
            GeoPosition? pos = await JS.InvokeAsync<GeoPosition>("mapHelper.getLocation");
            searchLat = pos.Latitude;
            searchLng = pos.Longitude;
        }
        catch
        {
            // keep default SF coords
        }
        await Search();
    }

    private async Task LoadCsvAsync()
    {
        status = "Loading dataset...";
        StateHasChanged();
        var csv = await Http.GetStringAsync("sample-data/Mobile_Food_Facility_Permit.csv");
        allTrucks = ParseCsv(csv)
            .Where(t => t.Status == "APPROVED" && (t.Latitude ?? 0) != 0 && (t.Longitude ?? 0) != 0)
            .ToList();
    }

    private async Task Search()
    {
        if (allTrucks.Count == 0)
            await LoadCsvAsync();

        var keyword = foodFilter.Trim();
        var results = allTrucks
            .Where(t => string.IsNullOrEmpty(keyword) ||
                        t.FoodItems.Contains(keyword, StringComparison.OrdinalIgnoreCase))
            .OrderBy(t => Haversine(searchLat, searchLng, t.Latitude!.Value, t.Longitude!.Value))
            .Take(resultCount)
            .ToList();

        await JS.InvokeVoidAsync("mapHelper.init", searchLat, searchLng);
        await JS.InvokeVoidAsync("mapHelper.addLocationMarker", searchLat, searchLng);

        foreach (var t in results)
        {
            var popup = t.Applicant + " — " + t.Address
                + (string.IsNullOrEmpty(t.FoodItems) ? "" : "<br/>" + t.FoodItems);
            await JS.InvokeVoidAsync("mapHelper.addMarker", t.Latitude, t.Longitude, popup);
        }

        status = $"Showing {results.Count} trucks near ({searchLat:F4}, {searchLng:F4})"
            + (string.IsNullOrEmpty(keyword) ? "" : $" serving \"{keyword}\"");
        StateHasChanged();
    }

    private static double Haversine(double lat1, double lon1, double lat2, double lon2)
    {
        const double R = 6371;
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2)
              + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180)
              * Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }

    private IEnumerable<Truck> ParseCsv(string csv)
    {
        using var reader = new StringReader(csv);
        using var csvReader = new CsvReader(reader, new CsvConfiguration(System.Globalization.CultureInfo.InvariantCulture)
        {
            HeaderValidated = null,
            MissingFieldFound = null
        });
        return csvReader.GetRecords<Truck>().ToList();
    }

    private record GeoPosition(double Latitude, double Longitude);

    private class Truck
    {
        public string Applicant { get; set; } = "";
        public string Address { get; set; } = "";
        public string Status { get; set; } = "";
        public string FoodItems { get; set; } = "";
        public double? Latitude { get; set; }
        public double? Longitude { get; set; }
    }
}
